{
  "name": "z-bot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "daemon": "cargo watch -x \"run --manifest-path application/daemon/Cargo.toml\"",
