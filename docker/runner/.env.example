# GitHub Actions Self-Hosted Runner Configuration
# Copy this to .env and fill in your values

# Runner registration token (REQUIRED)
# Get from: GitHub repo > Settings > Actions > Runners > New self-hosted runner
RUNNER_TOKEN=

# Runner name (shown in GitHub UI)
RUNNER_NAME=zbot-local

# Repository URL
RUNNER_REPOSITORY_URL=https://github.com/phanijapps/zbot

# Runner labels (used in workflow runs-on)
RUNNER_LABELS=self-hosted,linux,x64,zbot
