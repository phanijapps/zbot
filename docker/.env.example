# z-Bot Docker Configuration
# Copy this to .env and customize as needed

# Host path to your z-Bot vault (agents, wards, config, data)
# Use ./start.sh or create this directory before docker compose starts.
# If Docker creates a missing bind-mount path, it may be owned by root.
VAULT_PATH=~/zbot

# Host port for z-Bot HTTP, static UI, and WebSocket `/ws`
HTTP_PORT=18791

# Optional ngrok tunnel. Start with:
#   docker compose --profile ngrok up -d
# Get a token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Optional reserved ngrok domain, for example: example.ngrok.app
NGROK_DOMAIN=

# Host port for the local ngrok inspector UI
NGROK_WEB_PORT=4040
